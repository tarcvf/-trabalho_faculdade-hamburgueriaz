<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout

        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".MainActivity"
        android:background="@drawable/backgroundgradient">
    <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" app:srcCompat="@mipmap/hamburguer_ico_foreground"
            android:id="@+id/imageView" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="50dp" app:layout_constraintHorizontal_bias="0.498"/>
    <TextView
            android:textStyle="bold"
            android:text="Faça já seu pedido!"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/textView"
            app:layout_constraintTop_toBottomOf="@+id/imageView"
            android:layout_marginTop="28dp" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintHorizontal_bias="0.305"
             android:textColor="#ffffff"/>
    <Spinner
            android:layout_width="223dp"
            android:layout_height="27dp" android:id="@+id/spinner_hamburgueres"
            app:layout_constraintTop_toBottomOf="@+id/textView" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" android:layout_marginTop="8dp"
            app:layout_constraintHorizontal_bias="0.473"
            android:entries="@array/hamburgueres_array" android:foregroundTint="#FDFBFB"
            android:textColor="#ffffff"/>
    <TextView
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:text="Adicionais"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/textView2"
            app:layout_constraintTop_toBottomOf="@+id/spinner_hamburgueres"
            android:layout_marginTop="32dp" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintHorizontal_bias="0.252"
            android:foregroundTint="#FDFBFB"/>
    <RadioGroup
            android:layout_width="239dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView2" android:layout_marginTop="8dp"
            android:id="@+id/radioGroup" android:foregroundTint="#FDFBFB">
        <RadioButton
                android:buttonTint="#EF0555"
                android:textColor="#ffffff"
                android:text="Bacon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" android:id="@+id/Bacon" android:textColorLink="#E91919"/>
        <RadioButton
                android:buttonTint="#EF0555"
                android:textColor="#ffffff"
                android:text="Queijo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" android:id="@+id/Queijo"/>
        <RadioButton
                android:buttonTint="#EF0555"
                android:textColor="#ffffff"
                android:text="Onion Rings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" android:id="@+id/Onionrings"/>
    </RadioGroup>
    <TextView
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:text="Quantidae"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/textView3"
            app:layout_constraintTop_toBottomOf="@+id/radioGroup" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" android:layout_marginTop="32dp"
            app:layout_constraintHorizontal_bias="0.247" android:foregroundTint="#FDFBFB"/>
    <LinearLayout
            android:textColor="#ffffff"
            android:orientation="horizontal"
            android:layout_width="279dp"
            android:layout_height="48dp"
            app:layout_constraintEnd_toEndOf="parent" app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView3" android:layout_marginTop="8dp"
            app:layout_constraintHorizontal_bias="0.651" android:id="@+id/linearLayout"
            android:foregroundTint="#FDFBFB">
        <Button
                android:textColor="#ffffff"
                android:text="+"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:id="@+id/addqtd" android:layout_weight="1"/>
        <EditText
                android:textColor="#ffffff"
                android:layout_width="143dp"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:ems="20"
                android:id="@+id/qtd" android:layout_weight="1" tools:text="1" android:textAlignment="center"/>
        <Button
                android:text="-"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:id="@+id/dimqtd" android:layout_weight="1"/>
    </LinearLayout>
    <TextView
            android:textStyle="bold"
            android:textColor="#ffffff"
            android:text="Resumo do pedido:"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/textView4"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout"
            android:layout_marginTop="28dp" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" app:layout_constraintHorizontal_bias="0.296"
            android:foregroundTint="#FDFBFB"/>
    <TextView
            android:textColor="#ffffff"
            android:text="R$ 0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:id="@+id/valorApagar" tools:layout_editor_absoluteY="580dp"
            app:layout_constraintStart_toEndOf="@+id/textView4" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.594" android:foregroundTint="#FDFBFB"/>
    <Button
            android:textColor="#ffffff"
            android:text="Fazer pedido"
            android:layout_width="266dp"
            android:layout_height="64dp" android:id="@+id/submit"
            app:layout_constraintTop_toBottomOf="@+id/textView4"
            app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" android:foregroundTint="#FDFBFB"/>
</androidx.constraintlayout.widget.ConstraintLayout>